<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:layout_margin="4dp"
	android:background="@drawable/card_background"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear41"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="12dp"
		android:gravity="center_vertical"
		android:orientation="horizontal">
		<ImageView
			android:id="@+id/foto"
			android:layout_width="70dp"
			android:layout_height="70dp"
			android:padding="4dp"
			android:background="#E0E0E0"
			android:src="@drawable/avatar"
			android:scaleType="centerCrop"
			android:focusable="false"
			android:contentDescription="Fotodelconejo"
			android:layout_marginEnd="12dp" />
		<LinearLayout
			android:id="@+id/linear42"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:layout_weight="1">
			<LinearLayout
				android:id="@+id/linear43"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/nombre"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="Nombre"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#333333"
					android:layout_weight="1"
					android:focusable="false"
					android:maxLines="1"
					android:ellipsize="end" />
				<TextView
					android:id="@+id/identificador"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:background="#F0F0F0"
					android:text="#ABC123"
					android:textSize="12sp"
					android:textColor="#666666"
					android:focusable="false"
					android:paddingHorizontal="6dp"
					android:paddingVertical="2dp"
					android:layout_marginStart="8dp" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear44"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/sexo"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Macho"
					android:textSize="14sp"
					android:textColor="#2196F3"
					android:focusable="false"
					android:drawablePadding="4dp" />
				<View
					android:id="@+id/view45"
					android:layout_width="1dp"
					android:layout_height="16dp"
					android:background="#E0E0E0"
					android:layout_marginHorizontal="8dp" />
				<TextView
					android:id="@+id/raza"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="4dp"
					android:text="Raza"
					android:textSize="14sp"
					android:textColor="#666666"
					android:focusable="false" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear46"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/peso"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="0.00 kg"
					android:textSize="14sp"
					android:textColor="#4CAF50"
					android:focusable="false" />
				<TextView
					android:id="@+id/edad"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="4dp"
					android:text="0 meses"
					android:textSize="14sp"
					android:textColor="#FF9800"
					android:focusable="false"
					android:layout_marginStart="16dp" />
			</LinearLayout>
		</LinearLayout>
		<ImageView
			android:id="@+id/indicador"
			android:layout_width="24dp"
			android:layout_height="24dp"
			android:src="@drawable/icon_cancel_twotone"
			android:scaleType="fitCenter"
			android:layout_gravity="center_vertical"
			android:focusable="false"
			android:contentDescription="Estado"
			android:layout_marginStart="8dp" />
	</LinearLayout>
</LinearLayout>
