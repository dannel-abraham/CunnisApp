<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="#F5F5F5">
	<LinearLayout
		android:id="@+id/linear14"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="16dp"
		android:background="#4CAF50"
		android:orientation="horizontal"
		android:elevation="4dp">
		<Button
			android:id="@+id/btnAtras"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:textSize="24sp"
			android:textColor="#FFFFFF"
			android:background="@android:drawable/ic_menu_revert" />
		<TextView
			android:id="@+id/textview25"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:gravity="center_horizontal|center_vertical"
			android:text="Editar Conejo"
			android:textSize="20sp"
			android:textStyle="bold"
			android:textColor="#FFFFFF"
			android:layout_weight="1" />
		<TextView
			android:id="@+id/tvIdentificador"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="@android:color/transparent"
			android:gravity="center_horizontal|center_vertical"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#4CAF50"
			android:layout_gravity="center_horizontal|center_vertical" />
	</LinearLayout>
	<ScrollView
		android:id="@+id/vscroll2"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:padding="16dp">
		<LinearLayout
			android:id="@+id/linear13"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/cardview7"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:orientation="vertical"
				android:background="@android:color/white"
				android:elevation="2dp">
				<LinearLayout
					android:id="@+id/linear40"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview67"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:text="Información Básica"
						android:textSize="16sp"
						android:textStyle="bold"
						android:textColor="#4CAF50" />
					<TextView
						android:id="@+id/textview68"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="4dp"
						android:text="Nombre *"
						android:textSize="14sp"
						android:textColor="#333333" />
					<EditText
						android:id="@+id/etNombre"
						android:layout_width="match_parent"
						android:layout_height="48dp"
						android:padding="12dp"
						android:background="@drawable/edittext_background"
						android:textSize="16sp"
						android:hint="Ej: Pelusa"
						android:maxLines="1" />
					<TextView
						android:id="@+id/textview69"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:layout_marginBottom="4dp"
						android:text="ID Único"
						android:textSize="14sp"
						android:textColor="#333333" />
					<TextView
						android:id="@+id/tvIdUnico"
						android:layout_width="match_parent"
						android:layout_height="48dp"
						android:padding="12dp"
						android:background="#E8F5E9"
						android:gravity="center_vertical"
						android:textSize="16sp"
						android:textColor="#2E7D32"
						android:clickable="false"
						android:maxLines="1"
						android:focusable="false" />
					<TextView
						android:id="@+id/textview70"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:layout_marginBottom="8dp"
						android:text="Sexo *"
						android:textSize="14sp"
						android:textColor="#333333" />
					<RadioGroup
						android:id="@+id/rgSexo"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<RadioButton
							android:id="@+id/rbMacho"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="Macho"
							android:textSize="12sp" />
						<RadioButton
							android:id="@+id/rbHembra"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="Hembra"
							android:textSize="12sp" />
					</RadioGroup>
					<TextView
						android:id="@+id/textview71"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:layout_marginBottom="4dp"
						android:text="Raza"
						android:textSize="14sp"
						android:textColor="#333333" />
					<EditText
						android:id="@+id/etRaza"
						android:layout_width="match_parent"
						android:layout_height="48dp"
						android:padding="12dp"
						android:background="@drawable/edittext_background"
						android:textSize="16sp"
						android:hint="Ej: Nueva Zelanda" />
					<TextView
						android:id="@+id/textview72"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:layout_marginBottom="4dp"
						android:text="Fecha Nacimiento *"
						android:textSize="14sp"
						android:textColor="#333333" />
					<LinearLayout
						android:id="@+id/linear41"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal">
						<EditText
							android:id="@+id/etFechaNacimiento"
							android:layout_width="0dp"
							android:layout_height="48dp"
							android:padding="12dp"
							android:background="@drawable/edittext_background"
							android:textSize="16sp"
							android:hint="YYYY-MM-DD"
							android:layout_weight="1"
							android:maxLines="1" />
						<Button
							android:id="@+id/btnSeleccionarFecha"
							android:layout_width="48dp"
							android:layout_height="48dp"
							android:background="#4CAF50"
							android:text="📅"
							android:textSize="16sp"
							android:textColor="#FFFFFF"
							android:layout_marginStart="8dp" />
					</LinearLayout>
					<TextView
						android:id="@+id/textview73"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:layout_marginBottom="4dp"
						android:text="Peso Actual (lb) *"
						android:textSize="14sp"
						android:textColor="#333333" />
					<EditText
						android:id="@+id/etPeso"
						android:layout_width="match_parent"
						android:layout_height="48dp"
						android:padding="12dp"
						android:background="@drawable/edittext_background"
						android:textSize="16sp"
						android:hint="Ej: 2.5"
						android:inputType="numberDecimal" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/cardview8"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:orientation="vertical"
				android:background="@android:color/white"
				android:elevation="2dp">
				<LinearLayout
					android:id="@+id/linear42"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview74"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:text="Foto del Conejo"
						android:textSize="16sp"
						android:textStyle="bold"
						android:textColor="#4CAF50" />
					<LinearLayout
						android:id="@+id/linear43"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical">
						<ImageView
							android:id="@+id/ivFoto"
							android:layout_width="150dp"
							android:layout_height="150dp"
							android:layout_marginBottom="16dp"
							android:background="#E0E0E0"
							android:src="@drawable/default_image"
							android:scaleType="centerCrop"
							android:contentDescription="Fotodelconejo" />
						<LinearLayout
							android:id="@+id/linear44"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<Button
								android:id="@+id/btnTomarFoto"
								android:layout_width="0dp"
								android:layout_height="48dp"
								android:background="#2196F3"
								android:text="📸 Tomar Foto"
								android:textSize="14sp"
								android:textColor="#FFFFFF"
								android:layout_weight="1"
								android:layout_marginEnd="8dp" />
							<Button
								android:id="@+id/btnSeleccionarFoto"
								android:layout_width="0dp"
								android:layout_height="48dp"
								android:background="#FF9800"
								android:text="📁 Galería"
								android:textSize="14sp"
								android:textColor="#FFFFFF"
								android:layout_weight="1"
								android:layout_marginStart="8dp" />
						</LinearLayout>
						<Button
							android:id="@+id/btnEliminarFoto"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginTop="8dp"
							android:background="@android:color/transparent"
							android:text="Eliminar foto"
							android:textSize="12sp"
							android:textColor="#F44336" />
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/cardview9"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:orientation="vertical"
				android:background="@android:color/white"
				android:elevation="2dp">
				<LinearLayout
					android:id="@+id/linear45"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview75"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						android:text="Información de Padres"
						android:textSize="16sp"
						android:textStyle="bold"
						android:textColor="#4CAF50" />
					<TextView
						android:id="@+id/textview76"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="4dp"
						android:text="Madre"
						android:textSize="14sp"
						android:textColor="#333333" />
					<Spinner
						android:id="@+id/spMadre"
						android:layout_width="match_parent"
						android:layout_height="48dp"
						android:padding="12dp"
						android:background="@drawable/spinner_background"
						android:spinnerMode="dropdown" />
					<TextView
						android:id="@+id/textview77"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:layout_marginBottom="4dp"
						android:text="Padre"
						android:textSize="14sp"
						android:textColor="#333333" />
					<Spinner
						android:id="@+id/spPadre"
						android:layout_width="match_parent"
						android:layout_height="48dp"
						android:padding="12dp"
						android:background="@drawable/spinner_background"
						android:spinnerMode="dropdown" />
					<TextView
						android:id="@+id/textview78"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="8dp"
						android:text="* Solo se muestran conejos del sexo correspondiente"
						android:textSize="12sp"
						android:textColor="#666666" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear46"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="24dp"
				android:orientation="horizontal">
				<Button
					android:id="@+id/btnCancelar"
					android:layout_width="0dp"
					android:layout_height="48dp"
					android:background="#F44336"
					android:text="Cancelar"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:layout_weight="1"
					android:layout_marginEnd="8dp" />
				<Button
					android:id="@+id/btnGuardar"
					android:layout_width="0dp"
					android:layout_height="48dp"
					android:background="#4CAF50"
					android:text="Guardar Cambios"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:layout_weight="1"
					android:layout_marginStart="8dp" />
			</LinearLayout>
			<TextView
				android:id="@+id/textview79"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:text="* Campos obligatorios\n* El ID único no se puede modificar"
				android:textSize="12sp"
				android:textColor="#666666" />
		</LinearLayout>
	</ScrollView>
</LinearLayout>
